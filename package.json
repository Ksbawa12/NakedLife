{
  "name": "book-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:library": "node scripts/generate-library.mjs",
    "generate:photos": "node scripts/generate-photos.mjs",
    "rename:photos": "node scripts/rename-photos.mjs",
    "predev": "node scripts/generate-library.mjs && node scripts/generate-photos.mjs",
    "prebuild": "node scripts/generate-library.mjs && node scripts/generate-photos.mjs",
    "export:book-pdfs": "node scripts/generate-library.mjs && node scripts/export-book-pdfs.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0"
  }
}
